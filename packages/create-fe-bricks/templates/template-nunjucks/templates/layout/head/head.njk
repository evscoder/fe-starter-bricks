{% macro content(data, path) %}
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>{{ page.title if page.title else data.title }}</title>
        <meta name="description" content="{{ data.description }}"/>
        {% block styles %}
            <link href="{{ staticPath.css }}/assets/css/vendor.css{{ version }}" rel="stylesheet">
            <link href="{{ staticPath.css }}/assets/css/styles.css{{ version }}" rel="stylesheet">
        {% endblock %}
        <link rel="icon" type="image/x-icon" href="{{ staticPath.img }}/favicons/apple-icon-57x57.png"/>
    </head>
{% endmacro %}
