//- this object will store the names (keys) of our mixin blocks
- const blocks = {};

//- store block function
mixin set(key)
    - blocks[key] = this.block

//- an example to demonstrate how it works
    mixin layout
      block
      .main
        - blocks.main()
      .side
        - blocks.side()

//- mixin calls that blocks
    +layout
      +set('main')
        p Main
      +set('side')
        p Side
