mixin Head(data)
    head
        meta(charset='utf-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        title=page.title ? page.title : data.title
        meta(name='description', content=data.description)
        link(rel="icon" type="image/x-icon" href=`${staticPath.img}/favicons/favicon.ico`)
        block styles
            link(rel='stylesheet', href=`${staticPath.css}/vendor.css${version}`)
            link(rel='stylesheet', href=`${staticPath.css}/styles.css${version}`)
