<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{ page.title ?? data.title }}</title>
    <meta name="description" content="{{ data.description }}"/>
    {% block styles %}
        <link href="{{ staticPath.css }}/vendor.css{{ version }}" rel="stylesheet">
        <link href="{{ staticPath.css }}/styles.css{{ version }}" rel="stylesheet">
    {% endblock %}
    <link rel="apple-touch-icon" sizes="57x57" href="{{ staticPath.img }}/favicons/favicon.ico"/>
</head>
