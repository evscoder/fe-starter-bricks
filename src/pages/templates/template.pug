block components
    include ../../components/mixins
    include ../../components/head/head
    include ../../components/layout/header/header
    include ../../components/layout/footer/footer

doctype html
html.no-js(lang=lang)
    +Head(head.default)
    body()&attributes(page.attrs)
        | %symbols%
        .page-wrapper
            block header
                +Header()
            main.page-content&attributes(page.content)
                block content
            block footer
                +Footer()

        block bottom
            script(src=`${staticPath.js}/vendor.js${version}`)
            script(src=`${staticPath.js}/main.js${version}`)
