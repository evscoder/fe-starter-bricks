{
  "name": "fe-starter-bricks-monorepo",
  "version": "1.0.1",
  "private": true,
  "description": "Monorepository for Fe Starter Bricks — templates and a CLI generator.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "(cd packages/create-fe-bricks && node bin/cli.js)",
    "patch": "npm --prefix packages/create-fe-bricks version patch",
    "publish:cli": "npm --prefix packages/create-fe-bricks publish --access public"
  },
  "keywords": [
    "cli",
    "starter",
    "frontend",
    "dev",
    "template",
    "gulp",
    "webpack",
    "pug",
    "nunjucks",
    "twig",
    "mjml",
    "typescript",
    "scss",
    "tailwindcss"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0"
  }
}
